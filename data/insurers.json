  "memos": {
    "life": {
      "解約": "解約はお電話でのお申し出後、所定の書類をご返送いただきます。解約返戻金の有無・金額はご契約により異なります。",
      "給付金・保険金請求": "入院・手術・通院・死亡など、給付事由により必要書類が異なります。まずはお電話・マイページでご連絡ください。",
      "住所・氏名変更": "ご住所の変更はマイページから24時間お手続き可能。お名前の変更は本人確認書類が必要です。",
      "受取人・払込変更": "受取人の変更は所定の請求書、保険料の払込方法・口座変更はマイページが便利です。",
      "口座振替→クレカ": "お支払い方法を口座振替からクレジットカード払いへ変更するお手続きです。マイページまたはお電話で承ります（商品・カードにより取扱いが異なります）。",
      "クレカ変更": "ご登録中のクレジットカードの変更（カード番号・有効期限の更新を含む）のお手続きです。マイページからのお手続きが便利です。"
    },
    "nonlife": {
      "解約": "中途解約のお手続きです。自動車保険は等級の引継ぎ・解約返戻金にご注意ください。",
      "給付金・保険金請求": "事故のご連絡・保険金のご請求はお早めに。多くの会社で事故受付は24時間365日対応です。",
      "住所・氏名変更": "ご住所・お車・補償内容の変更はマイページまたはお電話で承ります。",
      "受取人・払込変更": "保険料の払込方法・口座の変更、契約条件の変更を承ります。",
      "口座振替→クレカ": "保険料のお支払いを口座振替からクレジットカード払いへ変更するお手続きです。マイページまたはお電話で承ります（商品・カードにより取扱いが異なります）。",
      "クレカ変更": "ご登録中のクレジットカードの変更（カード番号・有効期限の更新を含む）のお手続きです。マイページからのお手続きが便利です。"
    },
    "kyosai": {
      "解約": "共済契約の解約（脱退）のお手続きです。割戻金・解約手当金は契約により異なります。",
      "給付金・保険金請求": "入院・手術・災害・死亡などの共済金請求。事由により必要書類が異なります。",
      "住所・氏名変更": "ご住所・お名前の変更はお電話または窓口で承ります。",
      "受取人・払込変更": "加入内容の変更・掛金の払込方法変更を承ります。",
      "口座振替→クレカ": "掛金のお支払いを口座振替からクレジットカード払いへ変更するお手続きです。お電話または窓口で承ります（団体・商品により取扱いが異なります）。",
      "クレカ変更": "ご登録中のクレジットカードの変更（カード番号・有効期限の更新を含む）のお手続きです。お電話または窓口で承ります。"
    },
    "mini": {
      "解約": "解約はお電話または書面でのお手続きです。少額短期保険は掛捨て型が中心で返戻金がない場合があります。",
      "給付金・保険金請求": "保険金のご請求は事由発生後お早めに。必要書類は商品により異なります。",
      "住所・氏名変更": "ご住所・お名前の変更はマイページまたはお電話で承ります。",
      "受取人・払込変更": "受取人の変更・保険料の支払方法変更を承ります。",
      "口座振替→クレカ": "保険料のお支払いを口座振替からクレジットカード払いへ変更するお手続きです。マイページまたはお電話で承ります（商品・カードにより取扱いが異なります）。",
      "クレカ変更": "ご登録中のクレジットカードの変更（カード番号・有効期限の更新を含む）のお手続きです。マイページからのお手続きが便利です。"
    },
    "agency": {
      "解約": "代理店はご契約のご相談・お取次ぎ窓口です。解約のお手続き・解約返戻金のご確認は、ご契約の引受保険会社で行います。担当者・店舗がご案内します。",
      "給付金・保険金請求": "まずは担当者・店舗へご相談ください。給付金・保険金の最終的なご請求手続きは、引受保険会社が承ります。",
      "住所・氏名変更": "ご住所・お名前の変更は、担当代理店または引受保険会社へご連絡ください。",
      "受取人・払込変更": "受取人・払込方法の変更は、担当代理店経由または引受保険会社でお手続きいただけます。",
      "口座振替→クレカ": "お支払い方法の変更可否は引受保険会社により異なります。担当代理店または各保険会社へご確認ください。",
      "クレカ変更": "ご登録クレジットカードの変更は引受保険会社でのお手続きとなります。担当代理店がご案内します。"
    }
  },
